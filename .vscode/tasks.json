{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "cargo build blazepilot",
            "type": "shell",
            "command": "cargo",
            "args": [
                "build",
                "--bin=blazepilot"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared"
            },
            "problemMatcher": ["$rustc"],
            "options": {
                "cwd": "${workspaceFolder}/blazer-app"
            }
        }
    ]
}